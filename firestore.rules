rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && isVerified() && request.auth.token.email == 'nubiz.artwork.studio@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // For AppSettings validation (Validation Blueprint)
    function isValidAppSettings(data) {
      return data.keys().hasAll(['heroPhoto', 'bands', 'ticketTiers'])
        && data.keys().size() == 3
        && data.heroPhoto is string
        && data.heroPhoto.size() <= 1000
        && data.bands is list
        && data.bands.size() <= 10
        && data.ticketTiers is list
        && data.ticketTiers.size() <= 20;
    }

    // Match block for settings config
    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin() && isValidAppSettings(request.resource.data) && isValidId(settingsId);
    }
  }
}
